# LLM Provider: dashscope 或 minimax
LLM_PROVIDER=dashscope

# DashScope (阿里百炼) 配置
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxx
DASHSCOPE_BASE_HTTP_API_URL=https://dashscope.aliyuncs.com/api/v1
BAILIAN_COMPATIBLE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen-max
DASHSCOPE_FAST=qwen-turbo

# MiniMax 配置
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.chat/v1
MINIMAX_MODEL=MiniMax-M2.7
MINIMAX_FAST=MiniMax-M2.7

# 其他配置
OPENAI_API_KEY=
TEMPERATURE=0.0
# 0 表示不在客户端限制，交由模型服务端上限控制
MAX_TOKENS=0
MAX_ITERATIONS=20
ROUTER_NAME=rule_based_router
SHOW_DEBUG_STREAM=false
SHOW_MODEL_THINK=false
# 0 表示不截断（CLI 显示 / 回传模型）
TOOL_OUTPUT_DISPLAY_MAX_CHARS=0
TOOL_OUTPUT_MODEL_MAX_CHARS=0
